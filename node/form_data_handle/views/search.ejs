<!DOCTYPE html>
<html>
  <head>
    <title><%= title %></title>
  </head>
  <body>
    <h1><%= title %></h1>
    <section>
      <h2>Search form</h2>
      <%- include("partials/errors.ejs") %>
      <form action="/search" method="GET">
        <label for="name">Name contains:</label>
        <input
          type="search"
          id="name"
          name="name"
          value="<%= searchCriteria ? searchCriteria.name : '' %>"
          maxlength="100"
          pattern="[A-Za-z\s'\-]*"
        />
        <label for="email">Email contains:</label>
        <input
          type="search"
          id="email"
          name="email"
          value="<%= searchCriteria ? searchCriteria.email : '' %>"
          maxlength="100"
          pattern="[A-Za-z0-9@._+\-]*"
        />
        <button type="submit">Search users</button>
      </form>
      <p>Use one field or both fields to search.</p>
    </section>
    <hr />
    <section>
      <h2>Search results</h2>
      <% if (!hasSearchCriteria) { %>
        <p>Enter a name, an email, or both to begin searching.</p>
      <% } else { %>
        <p>
          Criteria:
          Name = "<%= searchCriteria.name || "Any" %>",
          Email = "<%= searchCriteria.email || "Any" %>"
        </p>
        <p><%= totalResults %> result(s) found.</p>
        <% if (users.length === 0) { %>
          <p>No users matched your search criteria.</p>
        <% } else { %>
          <ul>
            <% users.forEach((user) => { %>
              <li>
                ID: <%= user.id %>, Name: <%= user.firstName %> <%= user.lastName %>,
                age: <%= user.age %>, email: <%= user.email %>, bio: <%= user.bio %>
                <a href="/<%= user.id %>/update">Update</a>
                <form action="/<%= user.id %>/delete" method="POST" style="display:inline;">
                  <button type="submit" onclick="return confirm('Are you sure you want to delete this user?');">Delete</button>
                </form>
              </li>
            <% }) %>
          </ul>
          <% if (totalPages > 1) { %>
            <nav aria-label="Search result pages">
              <% if (currentPage > 1) { %>
                <a href="/search?name=<%= encodeURIComponent(searchCriteria.name) %>&email=<%= encodeURIComponent(searchCriteria.email) %>&page=<%= currentPage - 1 %>">Previous</a>
              <% } %>
              <span>Page <%= currentPage %> of <%= totalPages %></span>
              <% if (currentPage < totalPages) { %>
                <a href="/search?name=<%= encodeURIComponent(searchCriteria.name) %>&email=<%= encodeURIComponent(searchCriteria.email) %>&page=<%= currentPage + 1 %>">Next</a>
              <% } %>
            </nav>
          <% } %>
        <% } %>
      <% } %>
    </section>
    <a href="/">Back to home</a>
  </body>
</html>
