<!DOCTYPE html>
<html>
<head>
  <title><%= title %></title>
</head>
<body>
  <h1><%= title %></h1>
  <form action="/search" method="get">
    <label for="name">Name: </label>
    <input type="search" name="name" id="name" maxlength="100" pattern="[A-Za-z\s'\-]*" />
    <label for="email">Email: </label>
    <input type="search" name="email" id="email" maxlength="100" pattern="[A-Za-z0-9@._+\-]*" />
    <button type="submit">Search</button>
  </form>
  <a href="/search">Advanced search</a>
  <ul>
    <% if (locals.users) {%>
      <% users.forEach(user => { %>
        <li>
        ID: <%= user.id %>, Name: <%= user.firstName %> <%= user.lastName %>,
        age: <%= user.age  %>,email: <%= user.email  %>,bio: <%= user.bio  %>
          <a href="/<%= user.id %>/update">Update</a>
          <form action="/<%= user.id %>/delete" method="POST" style="display:inline;">
        <button type="submit" onclick="return confirm('Are you sure you want to delete this user?');">Delete</button>
      </form>
        </li>
      <% }); %>
    <% } %>
  </ul>
  <a href="/create">Create a user</a>
</body>
</html>
